<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            padding-top: 2rem;
            padding-bottom: 2rem;
        }

        .container {
            max-width: 960px;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1 class="mb-4">User Management Dashboard</h1>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text">🔍</span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by username...">
                </div>
            </div>
            <div class="col-md-6">
                <div class="input-group">
                    <label class="input-group-text" for="roleFilter">Filter by Role</label>
                    <select class="form-select" id="roleFilter">
                        <option selected value="">All Roles</option>
                        <option value="ADMIN">Admin</option>
                        <option value="AGENT">Agent</option>
                        <option value="CLAIM_ADJUSTER">Claim Adjuster</option>
                        <option value="POLICYHOLDER">Policyholder</option>
                    </select>
                </div>
            </div>
        </div>

        <div id="statusMessage" class="alert alert-info" role="alert" style="display: none;"></div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Username</th>
                        <th scope="col">Email</th>
                        <th scope="col">Role</th>
                        <th scope="col">User ID</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function() {

            // --- CONFIGURATION ---
            // IMPORTANT: Replace with your actual API URL and a valid JWT from an ADMIN user.
            const API_BASE_URL = 'https://localhost:7118'; // Example: 'https://localhost:7123' or your deployed URL
            
            
          

                    const userDataString = localStorage.getItem('userData');
        let token = null;

        if (userDataString) {
            try {
                const userData = JSON.parse(userDataString);
                token = userData.token;
            } catch (e) {
                console.error("Failed to parse userData from localStorage", e);
            }
        }

        if (!token) {
            alert("No authentication token found. Please log in.");
            window.location.href = "/";
            return;
        }
            // ---------------------

            let allFetchedUsers = []; // Cache to store users from the API to avoid re-fetching

            // Main function to fetch users from the API
            function fetchUsers(role = '') {
                const apiUrl = `${API_BASE_URL}/api/Authentication/users` + (role ? `?role=${role}` : '');

                $('#statusMessage').text('Loading users...').removeClass('alert-danger').addClass('alert-info').show();
                $('#userTableBody').empty();

                $.ajax({
                    url: apiUrl,
                    method: 'GET',
                    headers: {
                        'Authorization': 'Bearer ' + token
                    },
                    success: function(data) {
                        allFetchedUsers = data;
                        renderTable(); // Render the table with the new data
                        $('#statusMessage').hide();
                    },
                    error: function(xhr, status, error) {
                        allFetchedUsers = [];
                        renderTable(); // Clear the table
                        let errorMessage = 'An error occurred while fetching users.';
                        if (xhr.status === 401) {
                            errorMessage = 'Authentication failed. Please check your JWT token.';
                        } else if (xhr.status === 403) {
                            errorMessage = 'Access Denied. You must be an ADMIN to view this page.';
                        } else if (xhr.status === 404) {
                            errorMessage = 'No users found for the selected role.';
                        }
                        $('#statusMessage').text(errorMessage).removeClass('alert-info').addClass('alert-danger').show();
                    }
                });
            }

            // Function to render the table based on the cached data and search term
            function renderTable() {
                const searchTerm = $('#searchInput').val().toLowerCase();
                const $tableBody = $('#userTableBody');
                $tableBody.empty();

                let counter = 0;

                if (allFetchedUsers.length === 0) {
                    return; // Don't do anything if there's no data
                }

                $.each(allFetchedUsers, function(index, user) {
                    // Client-side search by username
                    if (user.username.toLowerCase().includes(searchTerm)) {
                        counter++;
                        const tableRow = `
                            <tr>
                                <th scope="row">${counter}</th>
                                <td>${user.username}</td>
                                <td>${user.email}</td>
                                <td><span class="badge bg-primary">${user.role}</span></td>
                                <td>${user.userId}</td>
                            </tr>
                        `;
                        $tableBody.append(tableRow);
                    }
                });

                if (counter === 0 && searchTerm) {
                     $('#statusMessage').text(`No users found with username containing "${searchTerm}".`).removeClass('alert-danger').addClass('alert-warning').show();
                } else if (counter > 0) {
                     $('#statusMessage').hide();
                }
            }

            // --- EVENT HANDLERS ---

            // When the role filter dropdown changes, fetch new data from the API
            $('#roleFilter').on('change', function() {
                const selectedRole = $(this).val();
                fetchUsers(selectedRole);
            });

            // When the user types in the search bar, filter the existing data (no new API call)
            $('#searchInput').on('keyup', function() {
                renderTable();
            });

            // --- INITIAL LOAD ---
            // Fetch all users by default when the page loads
            fetchUsers();

        });
    </script>

</body>
</html>