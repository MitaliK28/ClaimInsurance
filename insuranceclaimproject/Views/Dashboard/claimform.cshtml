<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submit an Insurance Claim</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Poppins', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .form-container {
            background-color: #ffffff;
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            padding: 2.5rem;
            width: 100%;
            max-width: 600px;
            animation: fadeIn 1s ease-out;
        }
     

        h2 {
            font-weight: 600;
            color: #333;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }

        .btn-primary {
            background-color: #0d6efd;
            border: none;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            transition: transform 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #0b5ed7;
                transform: translateY(-3px);
            }

        .alert-dismissible {
            animation: slideIn 0.5s ease-out;
        }
        

        .progress-bar-container {
            height: 5px;
            background-color: #e9ecef;
            border-radius: 5px;
            overflow: hidden;
            margin-bottom: 1rem;
            display: none;
        }

        .progress-bar {
            background-color: #28a745;
            transition: width 0.4s ease;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h2>File a Claim</h2>
        <form id="claimForm" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="policyId" class="form-label">Policy ID</label>
                <input type="number" class="form-control" id="policyId" name="policyId" required>
            </div>
            <div class="mb-3">
                <label for="claimAmount" class="form-label">Claim Amount</label>
                <input type="number" class="form-control" id="claimAmount" name="claimAmount" step="0.01" min="0.01" required>
            </div>
            <div class="mb-3">
                <label for="documentFile" class="form-label">Supporting Document (Optional)</label>
                <input type="file" class="form-control" id="documentFile" name="documentFile">
                <div class="form-text">Accepted formats: PDF, JPG, PNG, DOC.</div>
            </div>
            <div class="mb-3" id="documentNameGroup" style="display: none;">
                <label for="documentName" class="form-label">Document Name</label>
                <input type="text" class="form-control" id="documentName" name="documentName" maxlength="100">
            </div>

            <div class="progress-bar-container">
                <div class="progress-bar" role="progressbar" style="width: 0%;"></div>
            </div>

            <button type="submit" class="btn btn-primary w-100" id="submitBtn">Submit Claim</button>
        </form>
        <div id="responseMessage" class="mt-4"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            const apiBaseUrl = 'https://localhost:7048/api/Claim'; // Replace with your actual API URL

            // Show/hide document name input based on file selection
            $('#documentFile').on('change', function() {
                if ($(this).val()) {
                    $('#documentNameGroup').slideDown();
                } else {
                    $('#documentNameGroup').slideUp();
                }
            });

            // Handle form submission
            $('#claimForm').on('submit', function(e) {
                e.preventDefault(); // Prevent default form submission

                // Get form data
                const formData = new FormData(this);
                const fileInput = $('#documentFile')[0];
                const hasFile = fileInput.files.length > 0;

                // Set the appropriate URL based on whether a document is attached
                const url = hasFile ? `${apiBaseUrl}/submit-with-document` : `${apiBaseUrl}/submit`;

                // Disable button and show progress bar
                $('#submitBtn').prop('disabled', true).text('Submitting...');
                $('.progress-bar-container').fadeIn();

                // AJAX request
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: formData,
                    contentType: false, // Required for FormData
                    processData: false, // Required for FormData
                    headers: {
                        'Authorization': 'Bearer YOUR_JWT_TOKEN' // <-- IMPORTANT: Replace with a valid JWT token
                    },
                    xhr: function() {
                        const xhr = new window.XMLHttpRequest();
                        xhr.upload.addEventListener('progress', function(evt) {
                            if (evt.lengthComputable) {
                                const percentComplete = (evt.loaded / evt.total) * 100;
                                $('.progress-bar').css('width', percentComplete + '%');
                            }
                        }, false);
                        return xhr;
                    },
                    success: function(response) {
                        // Handle success
                        const message = hasFile
                            ? `Claim submitted successfully! Your Claim ID is: <strong>${response.claimId}</strong>`
                            : `Claim submitted successfully! Your Claim ID is: <strong>${response.claimId}</strong>`;

                        showResponse('success', message);
                        $('#claimForm')[0].reset(); // Reset the form
                        $('#documentNameGroup').slideUp();
                    },
                    error: function(xhr, status, error) {
                        // Handle errors
                        let errorMessage = "An unknown error occurred.";
                        try {
                            const errorResponse = JSON.parse(xhr.responseText);
                            errorMessage = errorResponse.message || errorResponse.errors.DocumentFile[0] || "An error occurred during submission.";
                        } catch (e) {
                            // Fallback to generic message if JSON parsing fails
                            errorMessage = `An error occurred: ${xhr.statusText}`;
                        }
                        showResponse('danger', errorMessage);
                    },
                    complete: function() {
                        // Re-enable button and hide progress bar
                        $('#submitBtn').prop('disabled', false).text('Submit Claim');
                        $('.progress-bar-container').fadeOut();
                        $('.progress-bar').css('width', '0%');
                    }
                });
            });

            // Helper function to display messages
            function showResponse(type, message) {
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                `;
                $('#responseMessage').html(alertHtml);
            }
        });
    </script>

</body>
</html>