            height: 100%;
            border-left: 4px solid var(--accent-color);
        }

        .stats-section {
            background: linear-gradient(45deg, #f8fafc, #e2e8f0);
            padding: 4rem 0;
        }

        .stat-card {
            text-align: center;
            padding: 2rem;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            color: var(--primary-color);
            display: block;
        }

        .btn-primary-custom {
            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-primary-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
            }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
        }

        .section-title {
            position: relative;
            margin-bottom: 3rem;
        }

            .section-title::after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 4px;
                background: var(--accent-color);
                border-radius: 2px;
            }

