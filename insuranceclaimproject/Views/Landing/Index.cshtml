    <script>
        // Auto-sliding background and content functionality
        document.addEventListener('DOMContentLoaded', function() {
            const slides = document.querySelectorAll('.hero-slide');
            const contentSlides = document.querySelectorAll('.content-slide');
            const indicators = document.querySelectorAll('.indicator');
            let currentSlide = 0;
            const slideInterval = 6000; // 6 seconds

            function showSlide(n) {
                // Remove active class from all slides, content, and indicators
                slides.forEach(slide => slide.classList.remove('active'));
                contentSlides.forEach(content => content.classList.remove('active'));
                indicators.forEach(indicator => indicator.classList.remove('active'));

                // Normalize slide index
                if (n >= slides.length) currentSlide = 0;
                if (n < 0) currentSlide = slides.length - 1;

                // Show current slide, content, and indicator
                slides[currentSlide].classList.add('active');
                contentSlides[currentSlide].classList.add('active');
                indicators[currentSlide].classList.add('active');
            }

            function nextSlide() {
                currentSlide++;
                showSlide(currentSlide);
            }

            // Auto-slide functionality
            let slideTimer = setInterval(nextSlide, slideInterval);

            // Indicator click functionality
            indicators.forEach((indicator, index) => {
                indicator.addEventListener('click', () => {
                    currentSlide = index;
                    showSlide(currentSlide);
                    // Reset timer when user manually changes slide
                    clearInterval(slideTimer);
                    slideTimer = setInterval(nextSlide, slideInterval);
                });
            });

            // Pause on hover
            const heroSection = document.querySelector('.hero-section');
            heroSection.addEventListener('mouseenter', () => {
                clearInterval(slideTimer);
            });

            heroSection.addEventListener('mouseleave', () => {
                slideTimer = setInterval(nextSlide, slideInterval);
            });

            // Smooth scrolling for navigation links
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });
        });
    </script>
</body>
</html>