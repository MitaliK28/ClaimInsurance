            line-height: 1.6;
        }

        .hero-section {
            color: white;
            height: 80vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        /* Background slider styles */
        .hero-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }

        .hero-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0;
            transition: opacity 2s ease-in-out;
        }

            .hero-slide.active {
                opacity: 1;
            }

        /* Overlay to ensure text readability */
        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1;
        }

        .hero-content {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            transform: translateY(-50%);
            z-index: 2;
            height: 100%;
            width: 100%;
        }

        /* Content slide styles */
        .content-slide {
            opacity: 0;
            transform: translateX(30px);
            transition: all 0.8s ease-in-out;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

            .content-slide.active {
                opacity: 1;
                transform: translateX(0);
            }

        .card-hover {
            transition: all 0.3s ease;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

            .card-hover:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        .insurance-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
