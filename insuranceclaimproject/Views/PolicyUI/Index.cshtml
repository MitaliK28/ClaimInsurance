<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Policies</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .container {
            margin-top: 50px;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .card-header {
            background-color: #007bff;
            color: white;
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
        }

        .table thead th {
            background-color: #007bff;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0 text-white">Policy Management</h2>
                <button id="addPolicyBtn" class="btn btn-light" data-toggle="modal" data-target="#addPolicyModal">
                    <i class="fas fa-plus"></i> Add Policy
                </button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <input type="text" id="searchInput" class="form-control" placeholder="Search policies...">
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="policyTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Policy Number</th>
                                <th>Policyholder Name</th>
                                <th>Coverage Amount</th>
                                <th>Status</th>
                                <th>Created Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addPolicyModal" tabindex="-1" role="dialog" aria-labelledby="addPolicyModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addPolicyModalLabel">Add New Policy</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="addPolicyForm">
                        @* <div class="form-group">
                            <label for="policyNumber">Policy Number</label>
                            <input type="text" class="form-control" id="policyNumber" required>
                        </div> *@
                       
                        <div class="form-group">
                            <label for="coverageAmount">Coverage Amount</label>
                            <input type="number" class="form-control" id="coverageAmount" min="1" required>
                        </div>
                        <div class="form-group">
                            <label for="policyholderSelect">Policyholder</label>
                            <select class="form-control" id="policyholderSelect" required>
                                <option value="">Select Policyholder</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Save Policy</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editPolicyModal" tabindex="-1" role="dialog" aria-labelledby="editPolicyModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editPolicyModalLabel">Edit Policy</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="editPolicyForm">
                        <input type="hidden" id="editPolicyId">
                        <div class="form-group">
                            <label for="editCoverageAmount">Coverage Amount</label>
                            <input type="number" class="form-control" id="editCoverageAmount" min="1" required>
                        </div>
                        <div class="form-group">
                            <label for="editPolicyStatus">Policy Status</label>
                            <select class="form-control" id="editPolicyStatus" required>
                                <option value="1">Active</option>
                                <option value="2">Inactive</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Update Policy</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
        $(document).ready(function () {
            const API_BASE_URL = "/api/Policy";
            const AUTH_API_URL = "/api/Authentication";
            let allPolicies = [];

            const userDataString = localStorage.getItem('userData');
            let token = null;

            if (userDataString) {
                try {
                    const userData = JSON.parse(userDataString);
                    token = userData.token;
                } catch (e) {
                    console.error("Failed to parse userData from localStorage", e);
                }
            }

            if (!token) {
                alert("No authentication token found. Please log in.");
                window.location.href = "/";
                return;
            }

            // Call the function to fetch all policies on page load
            fetchPolicies();

            // New Logic: Call the function to fetch policyholders on page load
            fetchPolicyholders();

            // Remove the event listener for the modal, as the data is already fetched
            // $('#addPolicyModal').on('show.bs.modal', function () {
            //     fetchPolicyholders();
            // });

            function fetchPolicyholders() {
                $.ajax({
                    url: `${AUTH_API_URL}/policyholders`,
                    type: "GET",
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function (data) {
                        const $select = $('#policyholderSelect');
                        $select.empty();

                        if (data.length > 0) {
                            data.forEach(user => {
                                $select.append(`<option value="${user.id}">${user.username}</option>`);
                            });
                            $select.prop('disabled', false);
                        } else {
                            $select.append(`<option value="">No policyholders available</option>`);
                            $select.prop('disabled', true);
                        }
                    },
                    error: function (xhr) {
                        console.error("Failed to fetch policyholders:", xhr.responseJSON?.message || xhr.statusText);
                        alert("Failed to load policyholders. Please try again.");
                    }
                });
            }

            function fetchPolicies() {
                $.ajax({
                    url: API_BASE_URL,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        allPolicies = data;
                        renderPolicies(allPolicies);
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403) {
                            alert("Session expired or unauthorized access. Please log in again.");
                            window.location.href = "/";
                        } else {
                            alert("Failed to fetch policies: " + (xhr.responseJSON?.message || xhr.statusText));
                        }
                    }
                });
            }

            function renderPolicies(policies) {
                const $tableBody = $('#policyTable tbody');
                $tableBody.empty();
                if (policies.length === 0) {
                    $tableBody.append('<tr><td colspan="7" class="text-center">No policies found.</td></tr>');
                    return;
                }
                policies.forEach(policy => {
                    $tableBody.append(`
                        <tr>
                            <td>${policy.policyId}</td>
                            <td>${policy.policyNumber}</td>
                            <td>${policy.policyholderUsername}</td>
                            <td>$${policy.coverageAmount.toFixed(2)}</td>
                            <td><span class="badge badge-${getPolicyStatusClass(policy.policyStatus)}">${policy.policyStatus}</span></td>
                            <td>${new Date(policy.createdDate).toLocaleDateString()}</td>
                            <td>
                                <button class="btn btn-sm btn-info edit-btn" data-id="${policy.policyId}" data-toggle="modal" data-target="#editPolicyModal">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-danger delete-btn" data-id="${policy.policyId}">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `);
                });
            }

            function getPolicyStatusClass(status) {
                switch (status.toLowerCase()) {
                    case 'active':
                        return 'success';
                    case 'inactive':
                        return 'danger';
                    case 'pending':
                        return 'warning';
                    default:
                        return 'secondary';
                }
            }

            $('#addPolicyForm').submit(function (e) {
                e.preventDefault();
                const selectedPolicyholderId = $('#policyholderSelect').val();

                if (!selectedPolicyholderId) {
                    alert("Please select a policyholder.");
                    return;
                }

                const newPolicy = {
                    policyholderId: selectedPolicyholderId,
                    coverageAmount: parseFloat($('#coverageAmount').val())
                };

                $.ajax({
                    url: API_BASE_URL,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(newPolicy),
                    success: function (data) {
                        $('#addPolicyModal').modal('hide');
                        alert("Policy added successfully!");
                        fetchPolicies();
                    },
                    error: function (xhr) {
                        alert("Failed to add policy: " + (xhr.responseJSON?.message || xhr.statusText));
                    }
                });
            });

            $(document).on('click', '.edit-btn', function () {
                const policyId = $(this).data('id');
                const policy = allPolicies.find(p => p.policyId === policyId);
                if (policy) {
                    $('#editPolicyId').val(policy.policyId);
                    $('#editCoverageAmount').val(policy.coverageAmount);
                    const statusMap = { 'Active': 0, 'Inactive': 1, 'Pending': 2 };
                    $('#editPolicyStatus').val(statusMap[policy.policyStatus]);
                }
            });

            $('#editPolicyForm').submit(function (e) {
                e.preventDefault();
                const policyId = $('#editPolicyId').val();
                const updatedPolicy = {
                    coverageAmount: parseFloat($('#editCoverageAmount').val()),
                    policyStatus: parseInt($('#editPolicyStatus').val())
                };

                $.ajax({
                    url: `${API_BASE_URL}/${policyId}`,
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(updatedPolicy),
                    success: function () {
                        $('#editPolicyModal').modal('hide');
                        alert("Policy updated successfully!");
                        fetchPolicies();
                    },
                    error: function (xhr) {
                        alert("Failed to update policy: " + (xhr.responseJSON?.message || xhr.statusText));
                    }
                });
            });

            $(document).on('click', '.delete-btn', function () {
                const policyId = $(this).data('id');
                if (confirm("Are you sure you want to delete this policy?")) {
                    $.ajax({
                        url: `${API_BASE_URL}/${policyId}/cancel`,
                        type: "PUT",
                        headers: { "Authorization": "Bearer " + token },
                        success: function () {
                            alert("Policy deleted successfully!");
                            fetchPolicies();
                        },
                        error: function (xhr) {
                            alert("Failed to delete policy: " + (xhr.responseJSON?.message || xhr.statusText));
                        }
                    });
                }
            });

            $('#searchInput').on('keyup', function () {
                const searchTerm = $(this).val().toLowerCase();
                const filteredPolicies = allPolicies.filter(policy => {
                    return policy.policyNumber.toLowerCase().includes(searchTerm) ||
                           policy.policyholderUsername.toLowerCase().includes(searchTerm) ||
                           policy.policyStatus.toLowerCase().includes(searchTerm) ||
                           policy.policyId.toString().includes(searchTerm);
                });
                renderPolicies(filteredPolicies);
            });
        });
    </script>
</body>
</html>