            let currentUserId = null;

            // Get authentication data
            const userDataString = localStorage.getItem('userData');
            if (userDataString) {
                try {
                    const userData = JSON.parse(userDataString);
                    userToken = userData.token;
                    currentUserId = userData.id;
                } catch (e) {
                    console.error("Failed to parse userData from localStorage", e);
                }
            }

            // Handle Active Policy click
            $('#activePolicy').on('click', function(e) {
                e.preventDefault();

                if (!userToken || !currentUserId) {
                    alert('Authentication required. Please log in.');
                    return;
                }

                // Show modal and loading state
                $('#policyDetailsModal').modal('show');
                $('#policyDetailsLoading').show();
                $('#policyDetailsContent').hide();
                $('#policyDetailsError').addClass('d-none');

                // Fetch policy details
                $.ajax({
                    url: `${policyApiUrl}/user/${currentUserId}`,
                    type: 'GET',
                    headers: {
                        'Authorization': 'Bearer ' + userToken
                    },
                                   success: function(policyData) {
            $('#policyDetailsLoading').hide();

            if (policyData && policyData.policies && policyData.policies.length > 0) {
                const policy = policyData.policies[0]; // First policy
                const category = policyData.categories && policyData.categories.length > 0
                    ? policyData.categories[0]
                    : null;

                populatePolicyDetails(policy, category);
                $('#policyDetailsContent').show();
            } else {
                showPolicyDetailsError('No active policies found.');
            }
        }
        ,
                    error: function(xhr) {
                        $('#policyDetailsLoading').hide();
                        console.error('Error fetching policy details:', xhr);

                        let errorMessage = 'Failed to load policy details.';
                        if (xhr.status === 404) {
                            errorMessage = 'No policies found for this user.';
                        } else if (xhr.status === 401) {
                            errorMessage = 'Authentication failed. Please log in again.';
                        }

                        showPolicyDetailsError(errorMessage);
                    }
                });
            });

                           function populatePolicyDetails(policy, category) {
            // Category type
            $('#detailCategoryType').text(category ? category.categoryType : 'N/A');

            // Policy values
            $('#detailCoverageAmount').text(
                policy.coverageAmount ? `₹${policy.coverageAmount.toLocaleString()}` : 'N/A'
            );
            $('#detailPremium').text('N/A'); // backend doesn’t have premium yet
            $('#detailStartDate').text(new Date(policy.createdDate).toLocaleDateString());
            $('#detailEndDate').text('N/A'); // backend doesn’t have end date yet
            $('#detailStatus').text(policy.policyStatus);

            // Additional details
            let additionalHtml = `
                <div class="detail-item">
                    <span class="detail-label">Policy Number:</span>
                    <span class="detail-value">${policy.policyNumber}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Policy ID:</span>
                    <span class="detail-value">${policy.policyId}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">User ID:</span>
                    <span class="detail-value">${policy.policyholderId ?? category?.userId ?? '-'}</span>
                </div>
            `;
            $('#additionalDetails').html(additionalHtml);
        }



            // Handle Create Policy button clicks
            $(document).on('click', '.create-policy-btn', function(e) {
                e.preventDefault();

                if (!userToken || !currentUserId) {
                    alert('Authentication required. Please log in.');
                    return;
                }

                const policyType = $(this).data('policy-type');
                const button = $(this);

                // Disable button and show loading state
                button.prop('disabled', true)
                      .html('<i class="fas fa-spinner fa-spin me-1"></i>Creating...');

                // Prepare data for API
                const policyData = {
                    categoryType: policyType,
                    userId: currentUserId
                };

                // Call create policy API
                $.ajax({
                    url: policyApiUrl,
                    type: 'POST',
                    headers: {
                        'Authorization': 'Bearer ' + userToken,
                        'Content-Type': 'application/json'
                    },
                    data: JSON.stringify(policyData),
                    success: function(response) {
                        // Show success message
                        showToast('success', `Policy request for "${policyType}" submitted successfully!`);

                        // Reset button after delay
                        setTimeout(() => {
                            button.prop('disabled', false)
                                  .html('<i class="fas fa-plus me-1"></i>Create Policy');
                        }, 2000);
                    },
                    error: function(xhr) {
                        console.error('Error creating policy:', xhr);

                        let errorMessage = 'Failed to create policy request.';
                        try {
                            const errorResponse = JSON.parse(xhr.responseText);
                            errorMessage = errorResponse.message || errorMessage;
                        } catch (e) {
                            if (xhr.status === 401) {
                                errorMessage = 'Authentication failed. Please log in again.';
                            } else if (xhr.status === 400) {
                                errorMessage = 'Invalid policy data. Please try again.';
                            }
                        }

                        showToast('danger', errorMessage);

                        // Reset button
                        button.prop('disabled', false)
                              .html('<i class="fas fa-plus me-1"></i>Create Policy');
                    }
                });
            });


            // Function to show policy details error
            function showPolicyDetailsError(message) {
                $('#policyDetailsError').removeClass('d-none').html(`
                    <i class="fas fa-exclamation-triangle me-2"></i>${message}
                `);
                $('#policyDetailsError').show();
            }

            // Function to show toast notifications
            function showToast(type, message) {
                // Create toast container if it doesn't exist
                if (!$('#toastContainer').length) {
                    $('body').append('<div id="toastContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 1060;"></div>');
                }

                const toastId = 'toast_' + Date.now();
                const toastHtml = `
                    <div id="${toastId}" class="toast align-items-center text-white bg-${type} border-0" role="alert">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                `;

                $('#toastContainer').prepend(toastHtml);

                // Initialize and show toast
                const toastElement = new bootstrap.Toast(document.getElementById(toastId), {
                    autohide: true,
                    delay: 5000
                });
                toastElement.show();

                // Remove toast element after it's hidden
                $(`#${toastId}`).on('hidden.bs.toast', function() {
                    $(this).remove();
                });
            }
        });

        $(document).ready(function () {
            // Get userData from localStorage
            var userData = JSON.parse(localStorage.getItem("userData"));

            if (userData) {
                // Set username
                $("#userName").text(userData.username || "Guest");

                // Set email
                $("#userEmail").text(userData.email || "");
            }
        });

        // =================================================================================
        // NEW CODE: Disable "Create Policy" buttons for existing policies on page load
        // =================================================================================
        $(document).ready(function () {
            const userDataString = localStorage.getItem('userData');
            if (userDataString) {
                try {
                    const userData = JSON.parse(userDataString);
                    const userToken = userData.token;
                    const currentUserId = userData.id;

                    if (userToken && currentUserId) {
                        const policyCategoryApiUrl = `https://localhost:7118/api/PolicyCategory/${currentUserId}`;

                        // Fetch existing policies for the user
                        $.ajax({
                            url: policyCategoryApiUrl,
                            type: 'GET',
                            headers: {
                                'Authorization': 'Bearer ' + userToken
                            },
                            success: function (existingPolicies) {
                                if (existingPolicies && existingPolicies.length > 0) {
                                    // Iterate over each "Create Policy" button on the page
                                    $('.create-policy-btn').each(function () {
                                        const button = $(this);
                                        const policyType = button.data('policy-type');

                                        // Check if a policy of this type already exists in the API response
                                        const policyExists = existingPolicies.some(policy => policy.categoryType === policyType);

                                        if (policyExists) {
                                            // If it exists, disable the button and update its text
                                            button.prop('disabled', true)
                                                  .html('<i class="fas fa-check me-1"></i>Policy Exists');
                                        }
                                    });
                                }
                            },
                            error: function (xhr) {
                                console.error('Error fetching existing policy categories:', xhr);
                                // You can optionally show a toast notification for the error here
                            }
                        });
                    }
                } catch (e) {
                    console.error("Failed to parse userData from localStorage for policy check", e);
                }
            }
        });

              document.addEventListener('DOMContentLoaded', function () {
          const logoutBtn = document.getElementById('btnLogout');

          if (logoutBtn) {
            logoutBtn.addEventListener('click', function (e) {
              e.preventDefault(); // Stop the default navigation
              try {
                localStorage.removeItem('userData');
                console.log('userData removed');
              } catch (err) {
                console.error('Error removing userData:', err);
              }
              // Redirect manually after clearing storage
              window.location.href = logoutBtn.getAttribute('href');
            });
          }
        });
    </script>
</body>
</html>
