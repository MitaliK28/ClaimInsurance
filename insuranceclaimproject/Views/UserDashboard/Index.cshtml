<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediClaim Pro - My Dashboard</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2563eb;
            --secondary-color: #1e40af;
            --accent-color: #3b82f6;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --info-color: #06b6d4;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            padding-top: 70px;
        }

        .navbar-custom {
            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
            color: white !important;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: white !important;
                transform: translateY(-1px);
            }

        .notification-badge {
            position: relative;
        }

        .notification-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--danger-color);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse 2s infinite;
        }

        .dashboard-header {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            border-left: 5px solid var(--primary-color);
        }

        .policy-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .policy-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            .policy-card.individual-health {
                border-left-color: var(--success-color);
            }

            .policy-card.critical-illness {
                border-left-color: var(--danger-color);
            }

            .policy-card.personal-accident {
                border-left-color: var(--warning-color);
            }

        .policy-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            margin-bottom: 1rem;
        }

        .individual-health-icon {
            background: linear-gradient(45deg, var(--success-color), #059669);
        }

        .critical-illness-icon {
            background: linear-gradient(45deg, var(--danger-color), #dc2626);
        }

        .personal-accident-icon {
            background: linear-gradient(45deg, var(--warning-color), #d97706);
        }

        .btn-custom {
            border-radius: 25px;
            padding: 8px 20px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-apply {
            background: linear-gradient(45deg, var(--success-color), #059669);
            color: white;
        }

            .btn-apply:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
                color: white;
            }

        .btn-claim {
            background: linear-gradient(45deg, var(--info-color), #0891b2);
            color: white;
        }

            .btn-claim:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(6, 182, 212, 0.3);
                color: white;
            }

        .policy-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }

        .status-pending {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }

        .policy-details {
            background: #f8fafc;
            border-radius: 10px;
            padding: 1rem;
            margin-top: 1rem;
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .detail-label {
            font-weight: 600;
            color: #64748b;
        }

        .detail-value {
            font-weight: 500;
            color: #1e293b;
        }

        .quick-actions {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
        }

        .action-btn {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 1rem;
            text-align: center;
            transition: all 0.3s ease;
            text-decoration: none;
            color: #64748b;
            display: block;
            margin-bottom: 1rem;
        }

            .action-btn:hover {
                border-color: var(--primary-color);
                color: var(--primary-color);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(37, 99, 235, 0.1);
            }

        .action-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            display: block;
        }

        .fade-in {
            animation: fadeIn 0.6s ease-in-out;
        }

        .slide-in-right {
            animation: slideInRight 0.5s ease-in-out;
        }

        .notification-item {
            padding: 1rem;
            border-bottom: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }

            .notification-item:hover {
                background: #f8fafc;
            }

            .notification-item:last-child {
                border-bottom: none;
            }

        .notification-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
        }

        .notification-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }

        .notification-warning {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }

        .notification-info {
            background: rgba(6, 182, 212, 0.1);
            color: var(--info-color);
        }

        .floating-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
            transition: all 0.3s ease;
            z-index: 1000;
        }

            .floating-btn:hover {
                transform: scale(1.1);
                color: white;
            }
        /* Additional CSS for Support Ticket Modal */
        .ticket-item {
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .ticket-item:hover {
                transform: translateX(5px);
                background-color: #f8f9fa;
            }

        .ticket-status-open {
            border-left-color: #ffc107;
        }

        .ticket-status-in-progress {
            border-left-color: #0dcaf0;
        }

        .ticket-status-resolved {
            border-left-color: #198754;
        }

        .ticket-status-closed {
            border-left-color: #6c757d;
        }

        .status-badge-open {
            background: linear-gradient(45deg, #ffc107, #ffb300);
            color: #000;
        }

        .status-badge-in-progress {
            background: linear-gradient(45deg, #0dcaf0, #0aa2c0);
            color: #fff;
        }

        .status-badge-resolved {
            background: linear-gradient(45deg, #198754, #146c43);
            color: #fff;
        }

        .status-badge-closed {
            background: linear-gradient(45deg, #6c757d, #5a6268);
            color: #fff;
        }

        .ticket-meta {
            font-size: 0.85rem;
            color: #6c757d;
        }

        .ticket-description {
            font-size: 0.9rem;
            line-height: 1.4;
        }

        #issueDescription {
            resize: none;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
        }

            #issueDescription:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.1);
            }

        .char-count-warning {
            color: #f59e0b !important;
        }

        .char-count-danger {
            color: #ef4444 !important;
        }

        .animate-slide-down {
            animation: slideDown 0.4s ease-out;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-heartbeat me-2"></i>MediClaim Pro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="#policies">
                            <i class="fas fa-file-contract me-1"></i>My Policies
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#policies">
                            <i class="fas fa-clipboard-list me-1"></i>Claims
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link notification-badge" href="#" data-bs-toggle="modal" data-bs-target="#notificationModal">
                            <i class="fas fa-bell me-1"></i>
                            <span class="notification-count">3</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/" id="btnLogout">
                            <i class="fas fa-sign-out-alt me-1"></i>Logout
                        </a>
                       

                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="dashboard-header fade-in">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2 class="mb-2">
                        <i class="fas fa-user-circle text-primary me-2"></i>
                        Welcome, <span id="userName"></span>
                    </h2>
                    <p class="text-muted">
                        <i class="fas fa-envelope me-2"></i>
                        <span id="userEmail"></span>
                    </p>
                    <p class="text-muted mb-0">Manage your health insurance policies and claims</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex justify-content-lg-end gap-2 mt-3 mt-lg-0">
                        <span class="badge bg-success p-2">
                            <i class="fas fa-shield-alt me-1"></i>3 Active Policies
                        </span>
                        <span class="badge bg-info p-2">
                            <i class="fas fa-clock me-1"></i>Last Login: Today
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="quick-actions slide-in-right">
            <h5 class="mb-3">
                <i class="fas fa-bolt text-primary me-2"></i>Quick Actions
            </h5>
            <div class="row">
                <div class="col-lg-4 col-md-6">
                    <a href="#" class="action-btn" id="activePolicy">
                        <i class="fas fa-file-medical action-icon"></i>
                        <strong>Active Policy</strong>
                        <small class="d-block text-muted">View active policy</small>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <a href="#" class="action-btn" data-bs-toggle="modal" data-bs-target="#trackModal">
                        <i class="fas fa-search action-icon"></i>
                        <strong>Track Claims</strong>
                        <small class="d-block text-muted">Check claim status</small>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <a href="#" class="action-btn" data-bs-toggle="modal" data-bs-target="#supportModal">
                        <i class="fas fa-headset action-icon"></i>
                        <strong>Support Ticket</strong>
                        <small class="d-block text-muted">Get help & support</small>
                    </a>
                </div>

            </div>
        </div>

        <div id="policies">
            <h4 class="mb-4">
                <i class="fas fa-file-contract text-primary me-2"></i>My Insurance Policies
            </h4>

            <div class="policy-card individual-health fade-in">
                <div class="row">
                    <div class="col-md-2 text-center">
                        <div class="policy-icon individual-health-icon">
                            <i class="fas fa-user-shield"></i>
                        </div>
                        
                    </div>
                    <div class="col-md-7">
                        <h5 class="mb-2">Individual Health Insurance</h5>
                        <p class="text-muted mb-3">Covers hospitalization, pre and post-hospitalization, and day-care procedures. Ideal for individuals without dependents aged 18-65 years.</p>
                        <div class="policy-details">
                           
                            <div class="detail-item">
                                <span class="detail-label">Coverage Amount:</span>
                                <span class="detail-value">₹5,00,000</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Premium:</span>
                                <span class="detail-value">₹12,000/year</span>
                            </div>
                           
                      
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="d-grid gap-2">
                            <button class="btn btn-custom btn-apply create-policy-btn" data-policy-type="Individual Health Insurance">
                                <i class="fas fa-plus me-1"></i>Create Policy
                            </button>
                            <a href="#" class="btn btn-custom btn-claim" data-bs-toggle="modal" data-bs-target="#claimModal">
                                <i class="fas fa-file-medical me-1"></i>File Claim
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="policy-card critical-illness fade-in">
                <div class="row">
                    <div class="col-md-2 text-center">
                        <div class="policy-icon critical-illness-icon">
                            <i class="fas fa-heartbeat"></i>
                        </div>
                       
                    </div>
                    <div class="col-md-7">
                        <h5 class="mb-2">Critical Illness Insurance</h5>
                        <p class="text-muted mb-3">Provides lump sum payout on diagnosis of specific critical illnesses. Helps cover expensive treatments and income loss during recovery.</p>
                        <div class="policy-details">
                       
                            <div class="detail-item">
                                <span class="detail-label">Coverage Amount:</span>
                                <span class="detail-value">₹8,00,000</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Premium:</span>
                                <span class="detail-value">₹8,500/year</span>
                            </div>
                         
 @*                            <ul class="list-unstyled text-start mt-3">
                                <li><i class="fas fa-check text-success me-2"></i>Heart Attack coverage</li>
                                <li><i class="fas fa-check text-success me-2"></i>Cancer treatment</li>
                                <li><i class="fas fa-check text-success me-2"></i>Kidney Failure & Paralysis</li>
                                <li><i class="fas fa-check text-success me-2"></i>One-time claim benefit</li>
                            </ul> *@
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="d-grid gap-2">
                            <button class="btn btn-custom btn-apply create-policy-btn" data-policy-type="Critical Illness Insurance">
                                <i class="fas fa-plus me-1"></i>Create Policy
                            </button>
                            <a href="#" class="btn btn-custom btn-claim" data-bs-toggle="modal" data-bs-target="#claimModal">
                                <i class="fas fa-file-medical me-1"></i>File Claim
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="policy-card personal-accident fade-in">
                <div class="row">
                    <div class="col-md-2 text-center">
                        <div class="policy-icon personal-accident-icon">
                            <i class="fas fa-ambulance"></i>
                        </div>
                       
                    </div>
                    <div class="col-md-7">
                        <h5 class="mb-2">Personal Accident Insurance</h5>
                        <p class="text-muted mb-3">Covers accidental death, disability, and injury. Offers compensation and hospitalization benefits for permanent/partial disability.</p>
                        <div class="policy-details">
                          
                            <div class="detail-item">
                                <span class="detail-label">Coverage Amount:</span>
                                <span class="detail-value">₹3,00,000</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Premium:</span>
                                <span class="detail-value">₹2,400/year</span>
                            </div>
                          
                          
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="d-grid gap-2">
                            <button class="btn btn-custom btn-apply create-policy-btn" data-policy-type="Personal Accident Insurance">
                                <i class="fas fa-plus me-1"></i>Create Policy
                            </button>
                            <a href="#" class="btn btn-custom btn-claim" disabled>
                                <i class="fas fa-file-medical me-1"></i>Claim (Pending)
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="modal fade" id="policyDetailsModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="fas fa-file-contract me-2"></i>Policy Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- Loading Spinner -->
                    <div id="policyDetailsLoading" class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Loading policy details...</p>
                    </div>

                    <!-- Policy Details Content -->
                    <div id="policyDetailsContent" style="display: none;">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="card mb-3">
                                    <div class="card-header bg-light">
                                        <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Basic Information</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="detail-item">
                                            <span class="detail-label">Category Type:</span>
                                            <span class="detail-value" id="detailCategoryType">-</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Coverage Amount:</span>
                                            <span class="detail-value" id="detailCoverageAmount">-</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Premium:</span>
                                            <span class="detail-value" id="detailPremium">-</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card mb-3">
                                    <div class="card-header bg-light">
                                        <h6 class="mb-0"><i class="fas fa-calendar me-2"></i>Policy Timeline</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="detail-item">
                                            <span class="detail-label">Start Date:</span>
                                            <span class="detail-value" id="detailStartDate">-</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">End Date:</span>
                                            <span class="detail-value" id="detailEndDate">-</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Status:</span>
                                            <span class="detail-value" id="detailStatus">-</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Additional Details -->
                        <div class="card">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-list me-2"></i>Additional Information</h6>
                            </div>
                            <div class="card-body" id="additionalDetails">
                                <!-- Dynamic content will be loaded here -->
                            </div>
                        </div>
                    </div>

                    <!-- Error Message -->
                    <div id="policyDetailsError" class="alert alert-danger d-none">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Failed to load policy details. Please try again.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="notificationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-bell text-primary me-2"></i>Notifications
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="notification-item">
                        <div class="d-flex">
                            <div class="notification-icon notification-success">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1">Claim Approved</h6>
                                <p class="text-muted mb-1">Your Individual Health Insurance claim #IHI-CLM-2024-0123 has been approved for ₹25,000.</p>
                                <small class="text-muted">2 hours ago</small>
                            </div>
                        </div>
                    </div>
                    <div class="notification-item">
                        <div class="d-flex">
                            <div class="notification-icon notification-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1">Premium Due Reminder</h6>
                                <p class="text-muted mb-1">Your Critical Illness Insurance premium of ₹8,500 is due on June 20, 2025.</p>
                                <small class="text-muted">1 day ago</small>
                            </div>
                        </div>
                    </div>
                    <div class="notification-item">
                        <div class="d-flex">
                            <div class="notification-icon notification-info">
                                <i class="fas fa-info-circle"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1">Policy Application Update</h6>
                                <p class="text-muted mb-1">Your Personal Accident Insurance application is under review. Expected approval within 3-5 business days.</p>
                                <small class="text-muted">3 days ago</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Mark All as Read</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="claimModal" tabindex="-1">
        <div class="modal-dialog">
