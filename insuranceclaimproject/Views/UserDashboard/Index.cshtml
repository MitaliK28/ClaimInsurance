            });
        });

             $(document).ready(function () {
            const apiBaseUrl = 'https://localhost:7118/api/Claim/submit-with-document'; // Replace with your actual API URL

            // Show/hide document name input based on file selection
            $('#documentFile').on('change', function () {
                if ($(this).val()) {
                    $('#documentNameGroup').slideDown();
                } else {
                    $('#documentNameGroup').slideUp();
                }
            });

                    const userDataString = localStorage.getItem('userData');
        let token = null;

        if (userDataString) {
            try {
                const userData = JSON.parse(userDataString);
                token = userData.token;
            } catch (e) {
                console.error("Failed to parse userData from localStorage", e);
            }
        }

        if (!token) {
            alert("No authentication token found. Please log in.");
            window.location.href = "/Account/Login";
            return;
        }


            // Handle form submission
                   $('#claimForm').on('submit', function (e) {
            e.preventDefault();

            // Collect values
            const policyId = $('#policyId').val();
            const claimAmount = $('#claimAmount').val();
            const documentName = $('#documentName').val();
            const fileInput = $('#documentFile')[0];

            // Build FormData
            const formData = new FormData();
            formData.append("policyId", policyId);
            formData.append("claimAmount", claimAmount);
            formData.append("documentName", documentName);

            if (fileInput.files.length > 0) {
                formData.append("documentFile", fileInput.files[0]); // actual file
            }

            // AJAX request
            $.ajax({
                url: apiBaseUrl,
                type: "POST",
                data: formData,
                processData: false,   // ✅ important
                contentType: false,   // ✅ important
                headers: { "Authorization": "Bearer " + token },
                xhr: function () {
                    const xhr = new window.XMLHttpRequest();
                    xhr.upload.addEventListener("progress", function (evt) {
                        if (evt.lengthComputable) {
                            const percentComplete = (evt.loaded / evt.total) * 100;
                            $(".progress-bar").css("width", percentComplete + "%");
                        }
                    }, false);
                    return xhr;
                },
                success: function (response) {
                    const message = `Claim submitted successfully! Your Claim ID is: <strong>${response.claimId}</strong>`;
                    showResponse("success", message);
                    $("#claimForm")[0].reset();
                    $("#documentNameGroup").slideUp();
                },
                error: function (xhr) {
                    let errorMessage = "An unknown error occurred.";
                    try {
                        const errorResponse = JSON.parse(xhr.responseText);
                        errorMessage = errorResponse.message || "Error during submission.";
                    } catch (e) {
                        errorMessage = `Error: ${xhr.statusText}`;
                    }
                    showResponse("danger", errorMessage);
                },
                complete: function () {
                    $("#submitBtn").prop("disabled", false).text("Submit Claim");
                    $(".progress-bar-container").fadeOut();
                    $(".progress-bar").css("width", "0%");
                }
            });
        });


            // Helper to convert file to Base64 string
            function toBase64(file) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = () => resolve(reader.result.split(",")[1]); // only base64 part
                    reader.onerror = reject;
                });
            }

            // Helper function to display messages
            function showResponse(type, message) {
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                `;
                $('#responseMessage').html(alertHtml);
            }
        });

                $(document).ready(function () {
            const apiBaseUrl = 'https://localhost:7118/api/claim';
            let token = null;
            let policyholderId = null;

            // Get token + policyholderId from localStorage
            const userDataString = localStorage.getItem('userData');
            if (userDataString) {
                try {
                    const userData = JSON.parse(userDataString);
                    token = userData.token;
                    policyholderId = userData.id; // <-- ensure your backend stores UserId here
                } catch (e) {
                    console.error("Failed to parse userData from localStorage", e);
                }
            }

            if (!token || !policyholderId) {
                alert("No authentication found. Please log in.");
                window.location.href = "/Account/Login";
                return;
            }

            // Load claims when modal opens
            $('#trackModal').one('show.bs.modal', function () {
                $('#claimsList').empty();          // clear old data
                $('#noClaimsMsg').addClass("d-none");

                $.ajax({
                    url: `${apiBaseUrl}/policyholder/${policyholderId}/with-documents`,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (claims) {
                        if (!claims || claims.length === 0) {
                            $('#noClaimsMsg').removeClass("d-none");
                            return;
                        }

                        claims.forEach(claim => {
                            const statusClass =
                                claim.claimStatus === "Approved" ? "bg-success" :
                                claim.claimStatus === "Rejected" ? "bg-danger" :
                                "bg-warning text-dark";

                            const li = `
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Policy ID: ${claim.policyId}
                                    <span class="badge ${statusClass}">${claim.claimStatus}</span>
                                </li>
                            `;
                            $('#claimsList').append(li);
                        });
                    },
                    error: function (xhr) {
                        console.error("Error fetching claims", xhr);
                        $('#noClaimsMsg').removeClass("d-none").text("Failed to load claims.");
                    }
                });
            });
        });

                // Support Ticket Modal JavaScript
        $(document).ready(function () {
            const supportApiUrl = 'https://localhost:7118/api/SupportTicket';
            let userToken = null;
            let currentUserId = null;

            // Get authentication data
            const userDataString = localStorage.getItem('userData');
            if (userDataString) {
                try {
                    const userData = JSON.parse(userDataString);
                    userToken = userData.token;
                    currentUserId = userData.id;
                } catch (e) {
                    console.error("Failed to parse userData from localStorage", e);
                }
            }

            // Character count functionality
            $('#issueDescription').on('input', function() {
                const currentLength = $(this).val().length;
                const maxLength = 1000;
                const charCountElement = $('#charCount');

                charCountElement.text(currentLength);

                // Color coding for character count
                if (currentLength > 800) {
                    charCountElement.addClass('char-count-danger').removeClass('char-count-warning');
                } else if (currentLength > 600) {
                    charCountElement.addClass('char-count-warning').removeClass('char-count-danger');
                } else {
                    charCountElement.removeClass('char-count-warning char-count-danger');
                }
            });

            // Show ticket form when "Raise Ticket" button is clicked
            $('#raiseTicketBtn').on('click', function() {
                $('#ticketFormSection').slideDown(400).addClass('animate-slide-down');
                $(this).prop('disabled', true).html('<i class="fas fa-check me-2"></i>Form Opened');
                setTimeout(() => {
                    $('#issueDescription').focus();
                }, 500);
            });

            // Hide ticket form when cancel is clicked
            $('#cancelTicketBtn').on('click', function() {
                $('#ticketFormSection').slideUp(400);
                $('#raiseTicketBtn').prop('disabled', false).html('<i class="fas fa-plus-circle me-2"></i>Raise New Ticket');
                $('#supportTicketForm')[0].reset();
                $('#ticketResponseMessage').empty();
                $('#charCount').text('0').removeClass('char-count-warning char-count-danger');
            });

            // Handle support ticket form submission
            $('#supportTicketForm').on('submit', function(e) {
                e.preventDefault();

                if (!userToken || !currentUserId) {
                    showTicketResponse('danger', 'Authentication required. Please log in.');
                    return;
                }

                const issueDescription = $('#issueDescription').val().trim();

                if (!issueDescription) {
                    showTicketResponse('warning', 'Please describe your issue.');
                    return;
                }

                // Disable submit button
                const submitBtn = $(this).find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Submitting...');

                // Prepare data
                const ticketData = {
                    userId: currentUserId,
                    issueDescription: issueDescription
                };

                // Submit ticket
                $.ajax({
                    url: supportApiUrl,
                    type: 'POST',
                    headers: {
                        'Authorization': 'Bearer ' + userToken,
                        'Content-Type': 'application/json'
                    },
                    data: JSON.stringify(ticketData),
                    success: function(response) {
                        showTicketResponse('success', `Ticket created successfully! Ticket ID: <strong>#${response.ticketId}</strong>`);
                        $('#supportTicketForm')[0].reset();
                        $('#charCount').text('0').removeClass('char-count-warning char-count-danger');

                        // Hide form and reload tickets
                        setTimeout(() => {
                            $('#ticketFormSection').slideUp(400);
                            $('#raiseTicketBtn').prop('disabled', false).html('<i class="fas fa-plus-circle me-2"></i>Raise New Ticket');
                            loadUserTickets();
                        }, 2000);
                    },
                    error: function(xhr) {
                        let errorMessage = 'Failed to create ticket. Please try again.';
                        try {
                            const errorResponse = JSON.parse(xhr.responseText);
                            errorMessage = errorResponse.message || errorMessage;
                        } catch (e) {
                            errorMessage = `Error: ${xhr.statusText}`;
                        }
                        showTicketResponse('danger', errorMessage);
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i>Submit Ticket');
                    }
                });
            });

            // Load user tickets when modal opens
            $('#supportModal').on('show.bs.modal', function() {
                loadUserTickets();
            });

            // Refresh tickets button
            $('#refreshTicketsBtn').on('click', function() {
                $(this).html('<i class="fas fa-spinner fa-spin me-1"></i>Refreshing...');
                loadUserTickets();
                setTimeout(() => {
                    $(this).html('<i class="fas fa-sync-alt me-1"></i>Refresh');
                }, 1000);
            });

            // Function to load user tickets
            function loadUserTickets() {
                if (!userToken || !currentUserId) {
                    showNoTickets();
                    return;
                }

                $('#ticketsLoading').show();
                $('#ticketsList').empty();
                $('#noTicketsMessage').addClass('d-none');

                $.ajax({
                    url: `${supportApiUrl}/user/${currentUserId}`,
                    type: 'GET',
                    headers: {
                        'Authorization': 'Bearer ' + userToken
                    },
                    success: function(tickets) {
                        $('#ticketsLoading').hide();

                        if (!tickets || tickets.length === 0) {
                            showNoTickets();
                            return;
                        }

                        tickets.forEach((ticket, index) => {
                            const ticketElement = createTicketElement(ticket, index);
                            $('#ticketsList').append(ticketElement);
                        });
                    },
                    error: function(xhr) {
                        $('#ticketsLoading').hide();
                        console.error('Error loading tickets:', xhr);

                        if (xhr.status === 404) {
                            showNoTickets();
                        } else {
                            $('#ticketsList').html(`
                                <div class="alert alert-danger">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    Failed to load tickets. Please try refreshing.
                                </div>
                            `);
                        }
                    }
                });
            }

            // Function to create ticket element
            function createTicketElement(ticket, index) {
                const statusClass = `ticket-status-${ticket.ticketStatus.toLowerCase().replace('_', '-')}`;
                const badgeClass = `status-badge-${ticket.ticketStatus.toLowerCase().replace('_', '-')}`;
                const formattedDate = new Date(ticket.createdDate).toLocaleString();
                const truncatedDescription = ticket.issueDescription.length > 150
                    ? ticket.issueDescription.substring(0, 150) + '...'
                    : ticket.issueDescription;

                return `
                    <div class="list-group-item ticket-item ${statusClass} ticket-item-enter"
                         style="animation-delay: ${index * 0.1}s">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0 me-2">Ticket #${ticket.ticketId}</h6>
                                    <span class="badge ${badgeClass} rounded-pill px-2 py-1">
                                        ${ticket.ticketStatus.replace('_', ' ')}
                                    </span>
                                </div>
                                <p class="ticket-description mb-2">${truncatedDescription}</p>
                                <div class="ticket-meta">
                                    <i class="fas fa-clock me-1"></i>
                                    Created: ${formattedDate}
                                </div>
                            </div>
                            <div class="ms-3">
                                <button class="btn btn-sm btn-outline-primary" onclick="viewTicketDetails(${ticket.ticketId})">
                                    <i class="fas fa-eye me-1"></i>View
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }

            // Function to show no tickets message
            function showNoTickets() {
                $('#ticketsLoading').hide();
                $('#noTicketsMessage').removeClass('d-none');
            }

            // Function to show ticket response messages
            function showTicketResponse(type, message) {
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
                $('#ticketResponseMessage').html(alertHtml);

                // Auto-dismiss success messages
                if (type === 'success') {
                    setTimeout(() => {
                        $('#ticketResponseMessage .alert').fadeOut();
                    }, 5000);
                }
            }

            // Global function to view ticket details
            window.viewTicketDetails = function(ticketId) {
                // You can implement a detailed view modal here
                alert(`View details for ticket #${ticketId}`);
            };
        });

                $(document).ready(function() {
            const policyApiUrl = 'https://localhost:7118/api/PolicyCategory';
