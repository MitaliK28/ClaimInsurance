  "components": {
    "schemas": {
      "ActivateCategoryAndCreatePolicyDto": {
        "required": [
          "coverageAmount",
          "policyCategoryId"
        ],
        "type": "object",
        "properties": {
          "policyCategoryId": {
            "type": "integer",
            "format": "int32"
          },
          "coverageAmount": {
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "AssignAdjusterDto": {
        "required": [
          "adjusterId"
        ],
        "type": "object",
        "properties": {
          "adjusterId": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CategorySummaryDto": {
        "type": "object",
        "properties": {
          "activeCount": {
            "type": "integer",
            "format": "int32"
          },
          "pendingCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ClaimStatus": {
        "enum": [
          "Pending",
          "Approved",
          "Rejected"
        ],
        "type": "string"
      },
      "CreateDocumentDto": {
        "required": [
          "claimId",
          "documentName",
          "documentPath"
        ],
        "type": "object",
        "properties": {
          "claimId": {
            "type": "integer",
            "format": "int32"
          },
          "documentName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "documentPath": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "documentType": {
            "$ref": "#/components/schemas/DocumentType"
          }
        },
        "additionalProperties": false
      },
      "CreatePolicyCategoryDto": {
        "required": [
          "categoryType",
          "userId"
        ],
        "type": "object",
        "properties": {
          "categoryType": {
            "minLength": 1,
            "type": "string"
          },
          "userId": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreatePolicyDto": {
        "required": [
          "coverageAmount",
          "policyholderId"
        ],
